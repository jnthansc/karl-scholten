---
const {
  title,
  description,
  noindex = false,
  projectTitle,
  bodyClass,
}: {
  title: string;
  description?: string;
  noindex?: boolean;
  projectTitle?: string;
  bodyClass?: string;
} = Astro.props;

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    {description ? <meta name="description" content={description} /> : null}
    {noindex ? <meta name="robots" content="noindex,follow" /> : null}
    <title>{title}</title>
  </head>
<body class={bodyClass ?? ''}>
    <header class="site-header">
      <div class="brand-section">
        <a class="brand" href="/">Karl Scholten</a>
        {projectTitle ? <span class="project-title">{projectTitle}</span> : null}
      </div>
      <nav class="nav" aria-label="Main">
        <a href="/about/">About</a>
      </nav>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <a class="site-footer__legal" href="/imprint/">Imprint & Privacy</a>
        <small class="site-footer__copy">© {year} Karl Scholten</small>
      </div>
    </footer>
  </body>
</html>

<style>
  :global(:root) {
    font-size: 16px;
    color-scheme: light;
    --index-text-color: var(--fg);
    --bg: #ffffff;
    --fg: #0b0d10;
    --muted: #5b6472;
    --border: #e7e9ee;
    --card: #f6f7f9;
    --shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
    --radius: 16px;
    --max: 100%;
    --gutter: 10px;
    --sat: env(safe-area-inset-top, 0px);
    --sab: env(safe-area-inset-bottom, 0px);
    --sal: env(safe-area-inset-left, 0px);
    --sar: env(safe-area-inset-right, 0px);
    --header-pad-y: 12px;
    /* Wordmark: one 2rem line, default line-height 1.2 in chrome box model for offset math */
    --brand-font-size: 2rem;
    --brand-line: calc(var(--brand-font-size) * 1.2);
    --project-name-title-gap: 0px;
    --project-title-line: calc(0.9rem * 1.3);
    /* One-line header band (name + padding), no in-flow project title */
    --headerH: calc(
      var(--header-pad-y) + var(--sat) + var(--brand-line) + var(--header-pad-y)
    );
    /* Total fixed footer block (link + small + padding + home indicator) */
    --footerH: calc(8px + 1.1rem + 4px + 1.1rem + 8px + max(4px, var(--sab)));
    /* Viewport y from top through bottom of fixed project title line (mobile) */
    --project-chrome-total: calc(
      var(--header-pad-y) + var(--sat) + var(--brand-line) + var(--project-name-title-gap) + var(
          --project-title-line
        )
    );
  }

  :global(html) {
    height: 100%;
    background: #fff;
  }

  :global(body) {
    height: 100%;
    margin: 0;
    font-family: 'Google Sans', ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica,
      Arial, "Apple Color Emoji", "Segoe UI Emoji";
    font-size: inherit;
    background: #fff;
    color: var(--fg);
    overflow-x: hidden;
  }

  :global(*, *::before, *::after) {
    box-sizing: border-box;
  }

  :global(body.prep-hide) {
    opacity: 0;
  }

  :global(a) {
    color: inherit;
    text-decoration: none;
  }

  :global(a:hover) {
    text-decoration: underline;
  }

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: transparent;
    border-bottom: none;
  }

  .site-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: calc(var(--header-pad-y) + var(--sat)) calc(var(--gutter) + var(--sar)) var(--header-pad-y) calc(var(--gutter) + var(--sal));
  }

  .brand-section {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .brand {
    font-size: var(--brand-font-size);
    font-weight: 650;
    letter-spacing: 0.2px;
  }

  .project-title {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.3;
    color: var(--fg);
  }

  .nav {
    display: flex;
    gap: 14px;
    color: var(--fg);
    font-size: 1.2rem;
  }

  .site-main {
    max-width: var(--max);
    margin: 0;
    padding: 0 calc(var(--gutter) + var(--sal)) calc(var(--footerH) + 24px) calc(var(--gutter) + var(--sar));
  }

  @media (max-width: 900px) {
    .site-main {
      padding: 0;
      padding-left: 0;
      padding-right: 0;
      padding-bottom: calc(var(--footerH) + 20px);
    }
  }

  .site-footer {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    min-height: var(--footerH);
    box-sizing: border-box;
    display: flex;
    align-items: center;
    color: var(--fg);
    padding: 8px calc(var(--gutter) + var(--sar)) max(4px, var(--sab)) calc(var(--gutter) + var(--sal));
    background: transparent;
    border-top: none;
    z-index: 1000;
    font-size: 1.1rem;
  }

  .site-footer__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 4px;
    max-width: var(--max);
  }

  .site-footer__legal {
    display: block;
    line-height: 1.2;
    font-size: smaller;
  }

  .site-footer__copy {
    display: block;
    line-height: 1.2;
    max-width: var(--max);
    margin: 0;
  }

  @media (max-width: 900px) {
    :global(body.project-page) .site-header .project-title {
      position: fixed;
      left: calc(var(--gutter) + var(--sal));
      top: calc(
        var(--header-pad-y) + var(--sat) + var(--brand-line) + var(--project-name-title-gap)
      );
      margin: 0;
    }

    :global(body.index-page) .site-header,
    :global(body.index-page) .site-header .brand,
    :global(body.index-page) .site-header .project-title,
    :global(body.index-page) .nav,
    :global(body.index-page) .nav a,
    :global(body.index-page) .site-footer,
    :global(body.index-page) .site-footer a,
    :global(body.index-page) .site-footer__legal,
    :global(body.index-page) .site-footer__copy,
    :global(body.index-page) .site-footer small {
      color: var(--index-text-color);
    }
  }
</style>

