---
const {
  title,
  description,
  noindex = false,
  projectTitle,
  bodyClass,
}: {
  title: string;
  description?: string;
  noindex?: boolean;
  projectTitle?: string;
  bodyClass?: string;
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    {description ? <meta name="description" content={description} /> : null}
    {noindex ? <meta name="robots" content="noindex,follow" /> : null}
    <title>{title}</title>
  </head>
<body class={bodyClass ?? ''}>
    <header class="site-header">
      <div class="brand-section">
        <a class="brand" href="/">Karl Scholten</a>
        {projectTitle ? <span class="project-title">{projectTitle}</span> : null}
      </div>
      <nav class="nav">
        <a href="/about/">About</a>
        <a href="/imprint/">Imprint</a>
      </nav>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <small>© {new Date().getFullYear()} Karl Scholten</small>
    </footer>
  </body>
</html>

<style>
  :global(:root) {
    font-size: 16px;
    color-scheme: light;
    --index-text-color: var(--fg);
    --bg: #ffffff;
    --fg: #0b0d10;
    --muted: #5b6472;
    --border: #e7e9ee;
    --card: #f6f7f9;
    --shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
    --radius: 16px;
    --max: 100%;
    --headerH: 44px;
    --footerH: 44px;
    --project-title-gap: 0px;
    --sat: env(safe-area-inset-top, 0px);
    --sab: env(safe-area-inset-bottom, 0px);
  }

  :global(html, body) {
    height: 100%;
  }

  :global(*, *::before, *::after) {
    box-sizing: border-box;
  }

  :global(body) {
    margin: 0;
    font-family: 'Google Sans', ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica,
      Arial, "Apple Color Emoji", "Segoe UI Emoji";
    font-size: inherit;
    background: var(--bg);
    color: var(--fg);
    overflow-x: hidden;
  }

  :global(body.prep-hide) {
    opacity: 0;
  }

  :global(a) {
    color: inherit;
    text-decoration: none;
  }

  :global(a:hover) {
    text-decoration: underline;
  }

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: transparent;
    border-bottom: none;
  }

  .site-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 10px;
  }

  .brand-section {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .brand {
    font-size: 1.5rem;
    font-weight: 650;
    letter-spacing: 0.2px;
  }

  .project-title {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.3;
    color: var(--fg);
  }

  .nav {
    display: flex;
    gap: 14px;
    color: var(--fg);
    font-size: 1.2rem;
  }

  .site-main {
    max-width: var(--max);
    margin: 0;
    padding: 0 10px calc(var(--footerH) + 24px);
  }

  @media (max-width: 900px) {
    .site-main {
      padding: 0;
    }
  }

  .site-footer {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    height: var(--footerH);
    display: flex;
    align-items: center;
    color: var(--fg);
    padding: 0 10px;
    background: transparent;
    border-top: none;
    z-index: 1000;
    font-size: 1.1rem;
  }

  .site-footer > small {
    display: block;
    max-width: var(--max);
    margin: 0;
  }

  @media (max-width: 900px) {
    :global(body.project-page) .site-header .project-title {
      position: fixed;
      left: calc(10px + env(safe-area-inset-left, 0px));
      top: calc(var(--headerH) + var(--project-title-gap) + env(safe-area-inset-top, 0px));
      margin: 0;
    }

    :global(body.index-page) .site-header,
    :global(body.index-page) .site-header .brand,
    :global(body.index-page) .site-header .project-title,
    :global(body.index-page) .nav,
    :global(body.index-page) .nav a,
    :global(body.index-page) .site-footer,
    :global(body.index-page) .site-footer small {
      color: var(--index-text-color);
    }
  }
</style>


