---
import BaseLayout from '../../layouts/BaseLayout.astro';
import groq from 'groq';
import { PROJECT_ORDER_FOR_NAV_QUERY } from '../../lib/homepage-projects';
import { getNextProject, type ProjectNavEntry } from '../../lib/next-project';
import { sanityClient, urlForImage } from '../../lib/sanity';

type ProjectDetail = {
  title: string;
  year?: number;
  indexTextColor?: 'black' | 'white';
  videoUrl?: string;
  images?: Array<{
    _key: string;
    alt?: string;
    asset?: { _id: string; url: string };
  }>;
};

const PROJECT_BY_SLUG_QUERY = groq`*[_type == "project" && slug.current == $slug][0]{
  title,
  year,
  indexTextColor,
  videoUrl,
  images[]{
    _key,
    alt,
    asset->{ _id, url }
  }
}`;

export async function getStaticPaths() {
  let ordered: ProjectNavEntry[] = [];
  try {
    ordered = await sanityClient.fetch<ProjectNavEntry[]>(PROJECT_ORDER_FOR_NAV_QUERY);
  } catch {
    ordered = [];
  }

  let slugRows: { slug: string }[] = [];
  try {
    slugRows = await sanityClient.fetch<{ slug: string }[]>(
      groq`*[_type == "project" && defined(slug.current)]{ "slug": slug.current }`,
    );
  } catch {
    slugRows = [];
  }

  return slugRows.map((s) => ({
    params: { slug: s.slug },
    props: {
      nextProject: getNextProject(ordered, s.slug),
    },
  }));
}

type Props = {
  nextProject: ProjectNavEntry | null;
};

const { slug } = Astro.params as { slug: string };
const { nextProject } = Astro.props as Props;
const project = await sanityClient.fetch<ProjectDetail | null>(PROJECT_BY_SLUG_QUERY, { slug });

// Convert YouTube/Vimeo URLs to embed format
function getEmbedUrl(url: string | undefined): string | undefined {
  if (!url) return undefined;
  
  try {
    const urlObj = new URL(url);
    
    // YouTube: convert watch URLs or short URLs to embed format
    if (urlObj.hostname.includes('youtube.com') || urlObj.hostname.includes('youtu.be')) {
      let videoId: string | null = null;
      
      if (urlObj.hostname.includes('youtu.be')) {
        // Short URL format: https://youtu.be/VIDEO_ID
        videoId = urlObj.pathname.slice(1);
      } else if (urlObj.pathname === '/watch' && urlObj.searchParams.has('v')) {
        // Regular URL format: https://www.youtube.com/watch?v=VIDEO_ID
        videoId = urlObj.searchParams.get('v');
      } else if (urlObj.pathname.startsWith('/embed/')) {
        // Already an embed URL
        return url;
      }
      
      if (videoId) {
        return `https://www.youtube.com/embed/${videoId}`;
      }
    }
    
    // Vimeo: convert regular URLs to embed format
    if (urlObj.hostname.includes('vimeo.com')) {
      const videoId = urlObj.pathname.split('/').filter(Boolean).pop();
      if (videoId && !urlObj.pathname.startsWith('/video/')) {
        return `https://player.vimeo.com/video/${videoId}`;
      } else if (urlObj.hostname.includes('player.vimeo.com')) {
        // Already an embed URL
        return url;
      }
    }
    
    // Return original URL if not YouTube/Vimeo or if conversion failed
    return url;
  } catch {
    // If URL parsing fails, return original
    return url;
  }
}

const embedUrl = project?.videoUrl ? getEmbedUrl(project.videoUrl) : undefined;
const hasImages = project?.images && project.images.length > 0;
const videoOnly = Boolean(embedUrl && !hasImages);
const videoWithImages = Boolean(embedUrl && hasImages);
const textColorClass =
  project?.indexTextColor === 'white' ? 'project-text-white' :
  project?.indexTextColor === 'black' ? 'project-text-black' : '';
---

<BaseLayout
  title={`${project?.year ? `${project.title} | ${project.year}` : project?.title ?? 'Project'} – Karl Scholten`}
  projectTitle={project?.year ? `${project.title} | ${project.year}` : project?.title}
  bodyClass={['project-page', textColorClass, videoOnly ? 'project-video-only' : '', videoWithImages ? 'project-video-with-images' : ''].filter(Boolean).join(' ')}
>
  <div
    class:list={[
      'project-content',
      videoOnly && 'video-only',
      videoWithImages && 'video-with-images',
    ]}
  >
    {project ? (
      <>
        {embedUrl ? (
          <section class="videoSection">
            <div class="videoFrame">
              <iframe
                src={embedUrl}
                title={`${project.title} video`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              />
            </div>
          </section>
        ) : null}

        <section class="stack" aria-label={`Images for ${project.title}`}>
          {(project.images ?? []).map((img, i) => (
            <figure class="frame" key={img._key}>
              {img.asset ? (
                <img
                  src={urlForImage(img).width(1600).quality(80).url()}
                  alt={img.alt ?? `${project.title} – image ${i + 1}`}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              ) : null}
            </figure>
          ))}
        </section>
      </>
    ) : (
      <p class="muted">Project not found.</p>
    )}
  </div>
  {project && nextProject ? (
    <a
      class="next-project-link"
      href={`/projects/${nextProject.slug}/`}
      aria-label={`Nächstes Projekt: ${nextProject.title}`}
    >
      next project{' '}
      <span class="next-project-arrow" aria-hidden="true">→</span>
    </a>
  ) : null}
</BaseLayout>

<script>
  (function initProjectVhUnderfill() {
    if (!document.body.classList.contains('project-page')) {
      return;
    }
    if (document.body.classList.contains('project-video-only')) {
      return;
    }
    if (document.body.classList.contains('project-video-with-images')) {
      return;
    }

    function syncProjectVhUnderfill() {
      const mobile = window.matchMedia('(max-width: 900px)').matches;
      if (!mobile) {
        document.body.classList.remove('project-vh-underfill');
        return;
      }
      const main = document.querySelector('main.site-main');
      if (!main) {
        return;
      }
      const tolerance = 2;
      const underfill = main.scrollHeight < window.innerHeight - tolerance;
      document.body.classList.toggle('project-vh-underfill', underfill);
    }

    syncProjectVhUnderfill();
    window.addEventListener('resize', syncProjectVhUnderfill);
    window.addEventListener('load', syncProjectVhUnderfill);
    const main = document.querySelector('main.site-main');
    if (main && typeof ResizeObserver !== 'undefined') {
      const ro = new ResizeObserver(() => syncProjectVhUnderfill());
      ro.observe(main);
    }
  })();
</script>

<style>
  :global(body.project-text-white .site-header),
  :global(body.project-text-white .site-header a),
  :global(body.project-text-white .site-header .brand),
  :global(body.project-text-white .site-header .brand-section),
  :global(body.project-text-white .site-header .project-title),
  :global(body.project-text-white .nav),
  :global(body.project-text-white .nav a),
  :global(body.project-text-white .site-footer),
  :global(body.project-text-white .site-footer small),
  :global(body.project-text-white .site-main),
  :global(body.project-text-white .project-content),
  :global(body.project-text-white .muted),
  :global(body.project-text-white .next-project-link) {
    color: #fff !important;
  }

  :global(body.project-text-black .site-header),
  :global(body.project-text-black .site-header a),
  :global(body.project-text-black .site-header .brand),
  :global(body.project-text-black .site-header .brand-section),
  :global(body.project-text-black .site-header .project-title),
  :global(body.project-text-black .nav),
  :global(body.project-text-black .nav a),
  :global(body.project-text-black .site-footer),
  :global(body.project-text-black .site-footer small),
  :global(body.project-text-black .site-main),
  :global(body.project-text-black .project-content),
  :global(body.project-text-black .muted),
  :global(body.project-text-black .next-project-link) {
    color: #000 !important;
  }

  @media (max-width: 900px) {
    :global(body.project-page.project-vh-underfill .site-header),
    :global(body.project-page.project-video-only .site-header),
    :global(body.project-page.project-video-with-images .site-header),
    :global(body.project-page.project-vh-underfill .site-header a),
    :global(body.project-page.project-video-only .site-header a),
    :global(body.project-page.project-video-with-images .site-header a),
    :global(body.project-page.project-vh-underfill .site-header .brand),
    :global(body.project-page.project-video-only .site-header .brand),
    :global(body.project-page.project-video-with-images .site-header .brand),
    :global(body.project-page.project-vh-underfill .site-header .brand-section),
    :global(body.project-page.project-video-only .site-header .brand-section),
    :global(body.project-page.project-video-with-images .site-header .brand-section),
    :global(body.project-page.project-vh-underfill .site-header .project-title),
    :global(body.project-page.project-video-only .site-header .project-title),
    :global(body.project-page.project-video-with-images .site-header .project-title),
    :global(body.project-page.project-vh-underfill .nav),
    :global(body.project-page.project-video-only .nav),
    :global(body.project-page.project-video-with-images .nav),
    :global(body.project-page.project-vh-underfill .nav a),
    :global(body.project-page.project-video-only .nav a),
    :global(body.project-page.project-video-with-images .nav a),
    :global(body.project-page.project-vh-underfill .site-footer),
    :global(body.project-page.project-video-only .site-footer),
    :global(body.project-page.project-video-with-images .site-footer),
    :global(body.project-page.project-vh-underfill .site-footer small),
    :global(body.project-page.project-video-only .site-footer small),
    :global(body.project-page.project-video-with-images .site-footer small),
    :global(body.project-page.project-vh-underfill .site-main),
    :global(body.project-page.project-video-only .site-main),
    :global(body.project-page.project-video-with-images .site-main),
    :global(body.project-page.project-vh-underfill .project-content),
    :global(body.project-page.project-video-only .project-content),
    :global(body.project-page.project-video-with-images .project-content),
    :global(body.project-page.project-vh-underfill .muted),
    :global(body.project-page.project-video-only .muted),
    :global(body.project-page.project-video-with-images .muted),
    :global(body.project-page.project-vh-underfill .next-project-link),
    :global(body.project-page.project-video-only .next-project-link),
    :global(body.project-page.project-video-with-images .next-project-link) {
      color: #000 !important;
    }
  }

  .project-content {
    width: 100%;
  }

  @media (max-width: 900px) {
    .project-content.video-only {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-height: 100vh;
      padding-top: calc(var(--headerH) + 20px);
      padding-bottom: calc(var(--footerH) + 20px);
      box-sizing: border-box;
    }

    /* Video + images: offset the embed downward without reserving space below it (no gap before images). */
    .project-content.video-with-images .videoSection {
      margin-bottom: 0;
      padding-top: clamp(32px, 12vh, 120px);
      box-sizing: border-box;
    }

    .project-content.video-with-images .stack {
      margin-top: 0;
    }
  }

  @media (min-width: 901px) {
    .project-content {
      margin-left: -10px;
      margin-right: -10px;
      width: calc(100% + 20px);
    }
  }


  .stack {
    display: grid;
    gap: 0;
  }

  .videoSection {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .project-content.video-only .videoSection {
      margin-bottom: 0;
    }
  }

  .videoFrame {
    position: relative;
    width: 100%;
    padding-top: 56.25%; /* 16:9 */
    border-radius: 0;
    overflow: hidden;
    border: none;
    box-shadow: var(--shadow);
    background: #000;
  }

  .videoFrame > iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .frame {
    margin: 0;
    border-radius: 0;
    overflow: hidden;
    border: none;
    background: #e9ecf2;
    box-shadow: var(--shadow);
  }

  .frame > img {
    width: 100%;
    height: auto;
    display: block;
  }

  :global(.next-project-link) {
    position: fixed;
    right: calc(10px + env(safe-area-inset-right, 0px));
    bottom: calc(10% + env(safe-area-inset-bottom, 0px));
    z-index: 1000;
    font-size: 1.2rem;
    line-height: 1.2;
  }

  :global(.next-project-arrow) {
    white-space: nowrap;
  }
</style>


