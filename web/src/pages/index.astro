---
import BaseLayout from '../layouts/BaseLayout.astro';
import {PROJECTS_FOR_INDEX_QUERY} from '../lib/homepage-projects';
import {sanityClient, urlForImage} from '../lib/sanity';

type ProjectCard = {
  _id: string;
  title: string;
  slug: string;
  indexTextColor?: 'black' | 'white';
  coverImage?: {
    alt?: string;
    asset?: {
      _id: string;
      url: string;
    };
  };
  mobileCoverImage?: {
    alt?: string;
    asset?: {
      _id: string;
      url: string;
    };
  };
};

let projects: ProjectCard[] = [];
try {
  projects = await sanityClient.fetch<ProjectCard[]>(PROJECTS_FOR_INDEX_QUERY);
} catch {
  projects = [];
}
projects = projects.filter((p) => Boolean(p.coverImage?.asset));
---

<BaseLayout title="Karl Scholten – Photographer" bodyClass="index-page">
  {projects.length === 0 ? (
    <p class="empty">No projects with cover images yet.</p>
  ) : (
    <>
    <span class="index-project-title" id="index-project-title" aria-hidden="true"></span>
    <div class="pageGrid">
      <aside class="desktopNames" aria-label="Projects">
        <div class="desktopNamesViewport">
          <div class="desktopNamesScroll">
            {Array.from({length: 3}).map((_, copyIdx) => (
              <ol class="desktopNamesList" data-copy-idx={copyIdx}>
                {projects.map((project, idx) => (
                  <li data-name-idx={idx}>
                    <a href={`/projects/${project.slug}/`} class="nameLink">{project.title}</a>
                  </li>
                ))}
              </ol>
            ))}
          </div>
        </div>
      </aside>
      <div class="snapRoot" aria-label="Project covers">
        {Array.from({length: 3}).map((_, copyIdx) =>
          projects.map((project, idx) => (
            <section
              class={`slide ${copyIdx === 1 ? 'primary' : 'clone'}`}
              data-idx={copyIdx * projects.length + idx}
              data-original-idx={idx}
              data-project-title={project.title}
              data-index-text-color={project.indexTextColor === 'white' ? '#fff' : project.indexTextColor === 'black' ? '#000' : undefined}
              aria-hidden={copyIdx === 1 ? 'false' : 'true'}
            >
              <a class="coverLink" href={`/projects/${project.slug}/`} aria-label={`Open ${project.title}`}>
                <picture>
                  {project.mobileCoverImage?.asset && (
                    <source
                      media="(max-width: 899px)"
                      srcset={urlForImage(project.mobileCoverImage).width(1200).quality(82).url()}
                    />
                  )}
                  <img
                    class="coverImg"
                    src={urlForImage(project.coverImage).width(2200).quality(82).url()}
                    alt={project.coverImage?.alt ?? project.title}
                    loading={copyIdx === 1 && idx === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </picture>
              </a>
            </section>
          )),
        )}
      </div>
    </div>
    </>
  )}
</BaseLayout>

<style>
  :global(body.index-page) {
    overflow: hidden;
    height: 100vh;
    height: 100dvh;
  }

  .empty {
    margin: 16px 0;
    color: var(--muted);
    font-size: 14px;
  }

  .pageGrid {
    display: block;
  }

  .desktopNames {
    display: none;
  }

  /* Mobile-first snap layout */
  .snapRoot {
    display: block;
    height: calc(100svh + var(--sat) + var(--sab));
    overflow-y: auto;
    overscroll-behavior: contain;
    touch-action: pan-y;
    scroll-snap-type: y mandatory;
    scroll-padding-top: 0;
    background: #000;
  }

  .snapRoot.ios26-plus {
    height: calc(124svh + var(--sat) + var(--sab));
  }

  .slide {
    position: relative;
    min-height: 100svh;
    height: 100svh;
    scroll-snap-align: start;
    margin: 0;
    background: #000;
  }

  .slide.ios26-plus {
    min-height: 124svh;
    height: 124svh;
  }

  .coverLink {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    margin-top: 0;
    margin-bottom: 0;
    overflow: hidden;
    text-decoration: none;
  }

  :global(.ios26-plus) .coverLink {
    height: calc(100% + var(--sat) + var(--sab) + var(--headerH));
    margin-top: calc(-1 * (var(--sat) + var(--headerH)));
    margin-bottom: calc(-1 * var(--sab));
  }

  .coverImg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background: #000;
  }

  .index-project-title {
    display: none;
  }

  @media (max-width: 900px) {
    .index-project-title {
      display: block;
      position: fixed;
      left: calc(var(--gutter) + var(--sal));
      top: calc(
        var(--header-pad-y) + var(--sat) + var(--brand-line) + var(--project-name-title-gap)
      );
      padding: 0;
      margin: 0;
      font-size: 0.9rem;
      line-height: 1.3;
      color: var(--index-text-color);
      z-index: 100;
      pointer-events: none;
    }
    :global(body) {
      touch-action: none;
    }

    :global(body.index-page .site-main) {
      padding-bottom: 0;
    }
  }

  /* Larger screens: disable snap, allow natural flow if desired */
  @media (min-width: 900px) {
    .pageGrid {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 16px;
      align-items: start;
    }

    .desktopNames {
      display: flex;
      align-items: center;
      justify-content: center;
      position: sticky;
      top: var(--headerH);
      grid-column: 1 / span 2;
      height: calc(100vh - var(--headerH));
      box-sizing: border-box;
    }

    .desktopNamesViewport {
      height: 352px;
      width: 100%;
      overflow: hidden;
      flex-shrink: 0;
    }

    .desktopNamesScroll {
      height: 100%;
      overflow-y: hidden;
    }

    .desktopNamesList {
      list-style: none;
      padding: 0;
      margin: 0;
      width: 100%;
    }

    .desktopNamesList > li {
      color: var(--muted);
      transition: color 0.2s ease;
      height: 32px;
      display: flex;
      align-items: center;
    }

    .desktopNamesList > li.active {
      color: var(--fg);
      font-weight: 600;
    }

    .nameLink {
      display: block;
      color: inherit;
      text-decoration: none;
      transition: color 0.2s ease;
      font-size: 1.1rem;
      width: 100%;
    }

    .nameLink:hover {
      color: var(--fg);
    }

    .snapRoot {
      grid-column: 3 / span 10;
      height: 100vh;
      scroll-snap-type: y mandatory;
      overflow-y: auto;
      background: #fff;
    }

    .slide {
      min-height: 100vh;
      height: 100vh;
      margin: 0;
      background: #fff;
    }

    .coverLink {
      height: 100%;
      margin-top: 0;
      margin-bottom: 0;
      padding: 100px 0;
      box-sizing: border-box;
    }

    .coverImg {
      height: 100%;
      object-fit: contain;
      background: #fff;
    }

  }
</style>

<script is:inline>
  (() => {
    // Detect iOS version and add class for iOS 26+
    function detectIOSVersion() {
      const userAgent = window.navigator.userAgent || window.navigator.vendor || window.opera;
      const isIOS = /iPad|iPhone|iPod/.test(userAgent) && !window.MSStream;
      
      if (!isIOS) return false;
      
      // For iOS 26+, the Safari Version number indicates the iOS version
      // Format: "Version/26.2" - check for Version/26 or higher
      const versionMatch = userAgent.match(/Version\/(\d+)/);
      if (versionMatch) {
        const safariVersion = parseInt(versionMatch[1], 10);
        return safariVersion >= 26;
      }
      
      // Fallback: Check OS version directly (for older iOS versions)
      // Format: "OS 26_0" or "OS 18_7"
      const osMatch = userAgent.match(/OS (\d+)[_\s]/);
      if (osMatch) {
        const iosVersion = parseInt(osMatch[1], 10);
        return iosVersion >= 26;
      }
      
      return false;
    }

    // Apply iOS 26+ class if detected (run immediately and on DOM ready)
    function applyIOS26Class() {
      if (detectIOSVersion()) {
        document.documentElement.classList.add('ios26-plus');
        const snapRoot = document.querySelector('.snapRoot');
        const slides = document.querySelectorAll('.slide');
        if (snapRoot) snapRoot.classList.add('ios26-plus');
        slides.forEach((slide) => slide.classList.add('ios26-plus'));
      }
    }

    // Run immediately if DOM is ready, otherwise wait for it
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', applyIOS26Class);
    } else {
      applyIOS26Class();
    }
  })();
</script>

<script is:inline>
  (() => {
    function isMobile() {
      return window.innerWidth < 900;
    }

    function onTouchMove(event) {
      if (!isMobile()) return;
      const target = event.target;
      if (target && target.closest && target.closest('.snapRoot')) {
        return;
      }
      event.preventDefault();
    }

    document.addEventListener('touchmove', onTouchMove, {passive: false});
  })();
</script>

<script is:inline>
  (() => {
    const root = document.querySelector('.snapRoot');
    const namesScroll = document.querySelector('.desktopNamesScroll');
    if (!root) return;

    const slides = Array.from(root.querySelectorAll('.slide'));
    if (!slides.length) return;

    const copies = 3;
    const totalHeight = () => root.scrollHeight / copies || 0;
    let singleHeight = totalHeight();

    const ITEM_HEIGHT = 32;
    const NAMES_VIEWPORT = ITEM_HEIGHT * 11;
    const getNamesSingleHeight = () => {
      if (!namesScroll) return 0;
      const listCount = namesScroll.querySelectorAll('.desktopNamesList').length;
      const itemsPerList = namesScroll.querySelectorAll('.desktopNamesList > li').length / listCount;
      return itemsPerList * ITEM_HEIGHT;
    };
    let namesSingleHeight = 0;

    const buffer = 120;
    let adjusting = false;

    const setNamesScrollToMiddle = () => {
      if (!namesScroll || !namesSingleHeight) return;
      const restore = namesScroll.style.scrollBehavior;
      namesScroll.style.scrollBehavior = 'auto';
      namesScroll.scrollTop = namesSingleHeight;
      namesScroll.style.scrollBehavior = restore;
    };

    const normalize = () => {
      if (adjusting || !singleHeight) return;
      const st = root.scrollTop;
      if (st <= buffer) {
        adjusting = true;
        const restore = root.style.scrollBehavior;
        root.style.scrollBehavior = 'auto';
        root.scrollTop = st + singleHeight;
        root.style.scrollBehavior = restore;
        if (namesScroll && namesSingleHeight) {
          const nsRestore = namesScroll.style.scrollBehavior;
          namesScroll.style.scrollBehavior = 'auto';
          namesScroll.scrollTop = namesScroll.scrollTop + namesSingleHeight;
          namesScroll.style.scrollBehavior = nsRestore;
        }
        adjusting = false;
      } else if (st >= singleHeight * 2 - buffer) {
        adjusting = true;
        const restore = root.style.scrollBehavior;
        root.style.scrollBehavior = 'auto';
        root.scrollTop = st - singleHeight;
        root.style.scrollBehavior = restore;
        if (namesScroll && namesSingleHeight) {
          const nsRestore = namesScroll.style.scrollBehavior;
          namesScroll.style.scrollBehavior = 'auto';
          namesScroll.scrollTop = namesScroll.scrollTop - namesSingleHeight;
          namesScroll.style.scrollBehavior = nsRestore;
        }
        adjusting = false;
      }
    };

    const onImageScroll = () => {
      normalize();
    };

    const init = () => {
      singleHeight = totalHeight();
      namesSingleHeight = getNamesSingleHeight();
      if (!singleHeight) return;
      const restore = root.style.scrollBehavior;
      root.style.scrollBehavior = 'auto';
      root.scrollTop = singleHeight;
      root.style.scrollBehavior = restore;
      setNamesScrollToMiddle();
    };

    root.addEventListener('scroll', onImageScroll, {passive: true});
    window.addEventListener('resize', () => {
      singleHeight = totalHeight();
      namesSingleHeight = getNamesSingleHeight();
    });

    window.addEventListener('load', () => {
      requestAnimationFrame(() => {
        namesSingleHeight = getNamesSingleHeight();
        init();
      });
    });
  })();
</script>

<script is:inline>
  (() => {
    // Mobile: update --index-text-color and --index-label-bg based on visible project
    const isMobile = () => window.innerWidth < 900;
    const root = document.querySelector('.snapRoot');
    if (root) {
      const allSlides = () => Array.from(root.querySelectorAll('.slide'));
      const updateIndexTextColor = () => {
        if (!isMobile()) return;
        const slides = allSlides();
        const viewportCenter = window.innerHeight / 2;
        let bestSlide = slides[0];
        let bestDist = Infinity;

        for (const slide of slides) {
          const r = slide.getBoundingClientRect();
          if (r.height <= 0) continue;
          const center = r.top + r.height / 2;
          const dist = Math.abs(center - viewportCenter);
          if (dist < bestDist) {
            bestDist = dist;
            bestSlide = slide;
          }
        }

        const color = bestSlide?.getAttribute('data-index-text-color') || '#000';
        const title = bestSlide?.getAttribute('data-project-title') || '';
        document.documentElement.style.setProperty('--index-text-color', color);
        const titleEl = document.getElementById('index-project-title');
        if (titleEl) titleEl.textContent = title;
      };

      root.addEventListener('scroll', () => {
        requestAnimationFrame(updateIndexTextColor);
      }, {passive: true});
      window.addEventListener('resize', updateIndexTextColor);
      updateIndexTextColor();
    }
  })();
</script>

<script is:inline>
  (() => {
    // Desktop-only name highlighting and names list scroll sync
    const isDesktop = () => window.innerWidth >= 900;

    const root = document.querySelector('.snapRoot');
    const namesScroll = document.querySelector('.desktopNamesScroll');
    const nameItems = Array.from(document.querySelectorAll('[data-name-idx]'));
    if (!nameItems.length || !root) return;

    const ITEM_HEIGHT = 32;
    const NAMES_VIEWPORT = ITEM_HEIGHT * 11;

    const getNamesSingleHeight = () => {
      if (!namesScroll) return 0;
      const listCount = namesScroll.querySelectorAll('.desktopNamesList').length;
      const itemsPerList = namesScroll.querySelectorAll('.desktopNamesList > li').length / listCount;
      return itemsPerList * ITEM_HEIGHT;
    };

    // Cache slides - they don't change after initial load
    const allSlides = Array.from(root.querySelectorAll('.slide'));

    let current = -1;
    const setActive = (idx) => {
      current = idx;
      nameItems.forEach((li) => li.classList.remove('active'));
      nameItems.filter((li) => Number(li.getAttribute('data-name-idx')) === idx).forEach((li) => li.classList.add('active'));
    };

    const syncNamesScroll = () => {
      if (!isDesktop() || !namesScroll) return;
      const imageSingleHeight = root.scrollHeight / 3;
      const namesSingleHeight = getNamesSingleHeight();
      if (!imageSingleHeight || !namesSingleHeight) return;
      const viewportH = window.innerHeight;
      const centerContentPos = root.scrollTop + viewportH / 2;
      const fraction = (centerContentPos - imageSingleHeight) / imageSingleHeight;
      let namesScrollTop = namesSingleHeight + fraction * namesSingleHeight - NAMES_VIEWPORT / 2;
      namesScrollTop = Math.max(0, Math.min(namesScrollTop, namesScroll.scrollHeight - NAMES_VIEWPORT));
      namesScroll.scrollTop = namesScrollTop;
    };

    const chooseByCenter = () => {
      const viewportCenter = window.innerHeight / 2;
      let bestIdx = 0;
      let bestDist = Infinity;
      let intersectingIdx = null;
      let intersectingDist = Infinity;

      // First pass: find covers that intersect the viewport center
      for (const cover of allSlides) {
        const r = cover.getBoundingClientRect();
        if (r.height <= 0) continue;
        
        const originalIdx = Number(cover.getAttribute('data-original-idx') || 0);
        const coverCenter = r.top + r.height / 2;
        
        // Check if cover intersects the viewport center
        const intersects = r.top <= viewportCenter && r.bottom >= viewportCenter;
        
        if (intersects) {
          const dist = Math.abs(coverCenter - viewportCenter);
          if (dist < intersectingDist) {
            intersectingDist = dist;
            intersectingIdx = originalIdx;
          }
        }
      }

      // If we found an intersecting cover, use it
      if (intersectingIdx !== null) {
        setActive(intersectingIdx);
        return;
      }

      // Second pass: find the closest cover to the viewport center
      for (const cover of allSlides) {
        const r = cover.getBoundingClientRect();
        if (r.height <= 0) continue;
        
        const originalIdx = Number(cover.getAttribute('data-original-idx') || 0);
        const coverCenter = r.top + r.height / 2;
        
        // Distance from cover center to viewport center
        const dist = Math.abs(coverCenter - viewportCenter);
        
        if (dist < bestDist) {
          bestDist = dist;
          bestIdx = originalIdx;
        }
      }

      setActive(bestIdx);
    };

    let raf = 0;
    let lastUpdate = 0;
    const throttleMs = 8; // Update at most every 8ms (~120fps)
    
    const onScroll = () => {
      if (!isDesktop()) return;

      syncNamesScroll();

      const now = performance.now();
      const timeSinceLastUpdate = now - lastUpdate;

      if (timeSinceLastUpdate >= throttleMs) {
        lastUpdate = now;
        chooseByCenter();
        if (raf) {
          window.cancelAnimationFrame(raf);
          raf = 0;
        }
      } else if (!raf) {
        raf = window.requestAnimationFrame(() => {
          raf = 0;
          lastUpdate = performance.now();
          chooseByCenter();
        });
      }
    };

    const scrollToProject = (idx) => {
      const slideHeight = root.scrollHeight / allSlides.length;
      const singleHeight = root.scrollHeight / 3;
      const viewportH = window.innerHeight;
      const targetCenter = idx * slideHeight + slideHeight / 2 - viewportH / 2;
      const currentScroll = root.scrollTop;
      const candidates = [
        targetCenter,
        singleHeight + targetCenter,
        singleHeight * 2 + targetCenter,
      ].map((t) => Math.max(0, Math.min(t, root.scrollHeight - viewportH)));
      const nearest = candidates.reduce((best, c) =>
        Math.abs(c - currentScroll) < Math.abs(best - currentScroll) ? c : best
      );
      root.style.scrollBehavior = 'smooth';
      root.scrollTop = nearest;
      setActive(idx);
      root.style.scrollBehavior = '';
    };

    document.querySelectorAll('.nameLink').forEach((link) => {
      link.addEventListener('click', (e) => {
        if (!isDesktop()) return;
        const li = link.closest('[data-name-idx]');
        if (!li) return;
        const idx = Number(li.getAttribute('data-name-idx'));
        if (idx === current) return;
        e.preventDefault();
        scrollToProject(idx);
      });
    });

    root.addEventListener('scroll', onScroll, {passive: true});
    window.addEventListener('resize', () => {
      onScroll();
    });

    syncNamesScroll();
    chooseByCenter();
  })();
</script>

<script is:inline>
  (() => {
    const root = document.querySelector('.snapRoot');
    if (!root) return;

    const allSlides = Array.from(root.querySelectorAll('.slide'));
    const projectCount = Math.round(allSlides.length / 3);
    if (projectCount <= 1 || allSlides.length < 3) return;

    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const IDLE_MS = 5000;
    const PROGRAMMATIC_SMOOTH_FALLBACK_MS = 2800;

    let idleTimeoutId = null;
    let ignoreScrollResetUntil = 0;

    function clearIdleTimer() {
      if (idleTimeoutId !== null) {
        window.clearTimeout(idleTimeoutId);
        idleTimeoutId = null;
      }
    }

    function shouldRunAutoAdvance() {
      if (document.visibilityState !== 'visible') return false;
      if (motionQuery.matches) return false;
      return true;
    }

    function scheduleIdleTimer() {
      clearIdleTimer();
      if (!shouldRunAutoAdvance()) return;
      idleTimeoutId = window.setTimeout(() => {
        idleTimeoutId = null;
        runAutoAdvance();
      }, IDLE_MS);
    }

    function resetIdleTimer() {
      scheduleIdleTimer();
    }

    function getCurrentOriginalIdx() {
      const viewportCenter = window.innerHeight / 2;
      let intersectingIdx = null;
      let intersectingDist = Infinity;
      let bestIdx = 0;
      let bestDist = Infinity;

      for (const cover of allSlides) {
        const r = cover.getBoundingClientRect();
        if (r.height <= 0) continue;

        const originalIdx = Number(cover.getAttribute('data-original-idx') || 0);
        const coverCenter = r.top + r.height / 2;
        const intersects = r.top <= viewportCenter && r.bottom >= viewportCenter;

        if (intersects) {
          const dist = Math.abs(coverCenter - viewportCenter);
          if (dist < intersectingDist) {
            intersectingDist = dist;
            intersectingIdx = originalIdx;
          }
        }
      }

      if (intersectingIdx !== null) {
        return intersectingIdx;
      }

      for (const cover of allSlides) {
        const r = cover.getBoundingClientRect();
        if (r.height <= 0) continue;

        const originalIdx = Number(cover.getAttribute('data-original-idx') || 0);
        const coverCenter = r.top + r.height / 2;
        const dist = Math.abs(coverCenter - viewportCenter);

        if (dist < bestDist) {
          bestDist = dist;
          bestIdx = originalIdx;
        }
      }

      return bestIdx;
    }

    /** Same target as sidebar navigation; smooth scroll matches user-driven scrolling. */
    function scrollToProjectSmooth(idx) {
      const slideHeight = root.scrollHeight / allSlides.length;
      const singleHeight = root.scrollHeight / 3;
      const viewportH = window.innerHeight;
      const targetCenter = idx * slideHeight + slideHeight / 2 - viewportH / 2;
      const currentScroll = root.scrollTop;
      const candidates = [
        targetCenter,
        singleHeight + targetCenter,
        singleHeight * 2 + targetCenter,
      ].map((t) => Math.max(0, Math.min(t, root.scrollHeight - viewportH)));
      const nearest = candidates.reduce((best, c) =>
        Math.abs(c - currentScroll) < Math.abs(best - currentScroll) ? c : best
      );
      const restore = root.style.scrollBehavior;
      root.style.scrollBehavior = 'smooth';
      root.scrollTop = nearest;
      root.style.scrollBehavior = restore;
    }

    function shieldStripScrollDuringProgrammaticSmooth() {
      ignoreScrollResetUntil = performance.now() + PROGRAMMATIC_SMOOTH_FALLBACK_MS;
      let finished = false;
      const release = () => {
        if (finished) return;
        finished = true;
        window.clearTimeout(fallbackId);
        root.removeEventListener('scrollend', release);
        ignoreScrollResetUntil = performance.now() + 80;
      };
      const fallbackId = window.setTimeout(release, PROGRAMMATIC_SMOOTH_FALLBACK_MS);
      root.addEventListener('scrollend', release, {once: true});
    }

    function runAutoAdvance() {
      if (!shouldRunAutoAdvance()) return;
      const currentIdx = getCurrentOriginalIdx();
      const nextIdx = (currentIdx + 1) % projectCount;
      shieldStripScrollDuringProgrammaticSmooth();
      scrollToProjectSmooth(nextIdx);
      scheduleIdleTimer();
    }

    function onStripScroll() {
      if (performance.now() < ignoreScrollResetUntil) return;
      resetIdleTimer();
    }

    function onVisibilityChange() {
      if (document.visibilityState === 'hidden') {
        clearIdleTimer();
      } else {
        resetIdleTimer();
      }
    }

    function onPrefersMotionChange() {
      if (motionQuery.matches) {
        clearIdleTimer();
      } else {
        resetIdleTimer();
      }
    }

    root.addEventListener('scroll', onStripScroll, {passive: true});
    window.addEventListener('resize', resetIdleTimer);
    document.addEventListener('visibilitychange', onVisibilityChange);
    if (typeof motionQuery.addEventListener === 'function') {
      motionQuery.addEventListener('change', onPrefersMotionChange);
    } else if (typeof motionQuery.addListener === 'function') {
      motionQuery.addListener(onPrefersMotionChange);
    }

    document.querySelectorAll('.nameLink').forEach((link) => {
      link.addEventListener('click', () => {
        resetIdleTimer();
      });
    });

    window.addEventListener('load', () => {
      window.requestAnimationFrame(() => {
        resetIdleTimer();
      });
    });
  })();
</script>

