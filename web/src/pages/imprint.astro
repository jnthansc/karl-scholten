---
import BaseLayout from '../layouts/BaseLayout.astro';
import groq from 'groq';
import { PortableText } from 'astro-portabletext';
import { sanityClient } from '../lib/sanity';

type SingletonPage = {
  title?: string;
  content?: any[];
};

const IMPRINT_QUERY = groq`*[_id in ["imprintPage","drafts.imprintPage"]][0]{
  title,
  content
}`;

let page: SingletonPage | null = null;
try {
  page = await sanityClient.fetch<SingletonPage | null>(IMPRINT_QUERY);
} catch {
  page = null;
}
---

<BaseLayout
  title="Imprint & Privacy – Karl Scholten"
  description="Legal information."
  bodyClass="imprint-page"
>
  <article class="content">
    <h1>{page?.title ?? 'Imprint & Privacy'}</h1>
    {page?.content?.length ? (
      <PortableText value={page.content} />
    ) : (
      <p>
        No Imprint &amp; Privacy content yet. Edit the legal page in Sanity and refresh.
      </p>
    )}
  </article>
</BaseLayout>

<style>
  :global(body.imprint-page .site-main) {
    padding-top: var(--headerH);
  }

  .content {
    max-width: 70ch;
    line-height: 1.65;
    color: var(--fg);
  }

  @media (max-width: 900px) {
    .content {
      padding-left: calc(var(--gutter) + var(--sal));
      padding-right: calc(var(--gutter) + var(--sar));
    }
  }

  h1 {
    margin: 0 0 12px;
    letter-spacing: -0.02em;
    color: var(--fg);
  }
</style>


